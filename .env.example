# Discord Bot Token
DISCORD_TOKEN=dein_discord_bot_token_hier

# Optional: Guild ID für Gildenspezifische Slash-Commands
# Lass 0 oder leer für globale Commands
GUILD_ID=0

# Channel-ID, in dem die Live-Embeds gepostet werden sollen
ANNOUNCE_CHANNEL_ID=123456789012345678

# Kommagetrennte Liste von Rollen-IDs, die Streamer-Befehle nutzen dürfen
# Info:
# Administration 123456789012345678
# Eventmanager 123456789012345678
# Clanleitung 123456789012345678
ALLOWED_ROLE_IDS=123456789012345678,123456789012345678,123456789012345678

# Twitch API
TWITCH_CLIENT_ID=dein_twitch_client_id
TWITCH_CLIENT_SECRET=dein_twitch_client_secret

# YouTube API
YOUTUBE_API_KEY=dein_youtube_api_key
